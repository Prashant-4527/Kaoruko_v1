# Kaoruko Environment Variables
# Copy this to .env and fill in your values.
# API keys are better stored via: python scripts/setup_windows.py
# or Settings > AI in the Kaoruko UI (machine-encrypted via SecretsManager).

# ── AI Providers (optional — use SecretsManager instead) ──────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true
LOG_CONSOLE=true

# ── Development ────────────────────────────────────────────────────────────
KAORUKO_DEV=false
